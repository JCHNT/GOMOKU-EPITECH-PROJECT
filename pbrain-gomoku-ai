#!/usr/bin/env python3

import sys

BOARD = None
BOARD_SIZE = 20
GAME_OVER = False
BOARD_CONFIG_MODE = False

def initialize_board(command):
    global BOARD, BOARD_SIZE
    parts = command.split()
    if len(parts) == 2:
        try:
            BOARD_SIZE = int(parts[1])
        except ValueError:
            BOARD_SIZE = 20
    else:
        BOARD_SIZE = 20
    if BOARD_SIZE != 20:
        print("ERROR message")
    else:
        print("OK")
    BOARD = [[' ' for _ in range(BOARD_SIZE)] for _ in range(BOARD_SIZE)]

def print_current_board():
    global BOARD, BOARD_SIZE
    for row in BOARD:
        print('|'.join(row))

def sanitize_input(text):
    return text[:-1] if text.endswith("\r") else text

def place_token(x, y, player):
    global BOARD
    if BOARD[y][x] == ' ':
        BOARD[y][x] = 'X' if player == 1 else 'O'
        return True
    return False

def check_winner():
    global BOARD, BOARD_SIZE
    for y in range(BOARD_SIZE):
        for x in range(BOARD_SIZE):
            if BOARD[y][x] != ' ':
                token = BOARD[y][x]
                if x + 4 < BOARD_SIZE and all(BOARD[y][x + i] == token for i in range(5)):
                    return token
                if y + 4 < BOARD_SIZE and all(BOARD[y + i][x] == token for i in range(5)):
                    return token
                if x + 4 < BOARD_SIZE and y + 4 < BOARD_SIZE and all(BOARD[y + i][x + i] == token for i in range(5)):
                    return token
                if x + 4 < BOARD_SIZE and y - 4 >= 0 and all(BOARD[y - i][x + i] == token for i in range(5)):
                    return token
    return None

def get_possible_moves():
    global BOARD, BOARD_SIZE
    moves = set()
    for y in range(BOARD_SIZE):
        for x in range(BOARD_SIZE):
            if BOARD[y][x] != ' ':
                for dy in range(-1, 2):
                    for dx in range(-1, 2):
                        new_x = x + dx
                        new_y = y + dy
                        if (0 <= new_x < BOARD_SIZE and 0 <= new_y < BOARD_SIZE and BOARD[new_y][new_x] == ' '):
                            moves.add((new_x, new_y))
    return moves if moves else [(x, y) for y in range(BOARD_SIZE) for x in range(BOARD_SIZE) if BOARD[y][x] == ' ']

def update_board_configuration(config_str):
    global BOARD
    parts = config_str.split(',')
    if len(parts) != 3:
        return
    try:
        x = int(parts[0])
        y = int(parts[1])
        player = int(parts[2])
        if player == 2:
            BOARD[y][x] = 'X'
        elif player == 1:
            BOARD[y][x] = 'O'
        else:
            print("ERROR Invalid player number")
    except ValueError:
        print("ERROR syntax error")

def evaluate_board():
    winner = check_winner()
    if winner == 'O':
        return 10
    elif winner == 'X':
        return -10
    return 0

def run_minimax(depth, is_maximizing, alpha, beta):
    score = evaluate_board()
    if score == 10 or score == -10:
        return score
    if depth >= 1:
        return 0
    if is_maximizing:
        best_val = -1
        for (x, y) in get_possible_moves():
            BOARD[y][x] = 'O'
            value = run_minimax(depth + 1, False, alpha, beta)
            BOARD[y][x] = ' '
            best_val = max(best_val, value)
            alpha = max(alpha, best_val)
            if beta <= alpha:
                break
        return best_val
    else:
        best_val = 1
        for (x, y) in get_possible_moves():
            BOARD[y][x] = 'X'
            value = run_minimax(depth + 1, True, alpha, beta)
            BOARD[y][x] = ' '
            best_val = min(best_val, value)
            beta = min(beta, best_val)
            if beta <= alpha:
                break
        return best_val

def find_best_move():
    best_score = -1
    best_move = (-1, -1)
    for (x, y) in get_possible_moves():
        BOARD[y][x] = 'O'
        move_score = run_minimax(0, False, -1, 1)
        BOARD[y][x] = ' '
        if move_score > best_score:
            best_score = move_score
            best_move = (x, y)
    return best_move

def execute_ai_turn():
    x, y = find_best_move()
    if x != -1 and y != -1:
        place_token(x, y, player=2)
        print(f"{x},{y}")

def reset_game_state():
    global BOARD, BOARD_SIZE, GAME_OVER, BOARD_CONFIG_MODE
    BOARD = None
    BOARD_SIZE = 20
    GAME_OVER = False
    BOARD_CONFIG_MODE = False

def main_loop():
    global GAME_OVER, BOARD_CONFIG_MODE
    valid_commands = ["START", "END", "BOARD", "DONE", "BEGIN", "RESTART", "ABOUT", "TURN", "INFO"]
    while not GAME_OVER:
        try:
            user_input = input("")
            user_input = sanitize_input(user_input)
            if not any(user_input.startswith(cmd) for cmd in valid_commands) and not BOARD_CONFIG_MODE:
                print(f"ERROR InvalidCommand: {user_input}")
                continue
            if user_input.startswith("START"):
                initialize_board(user_input)
                continue
            if user_input == "END":
                exit(0)
            if user_input == "BOARD" and not BOARD_CONFIG_MODE:
                BOARD_CONFIG_MODE = True
                continue
            if user_input == "DONE" and BOARD_CONFIG_MODE:
                BOARD_CONFIG_MODE = False
                execute_ai_turn()
                continue
            if BOARD_CONFIG_MODE:
                update_board_configuration(user_input)
                result = check_winner()
                if result == 'X':
                    print("Player 2 WINS")
                    GAME_OVER = True
                elif result == 'O':
                    print("Player 1 WINS")
                    GAME_OVER = True
                continue
            if user_input == "BEGIN":
                execute_ai_turn()
                continue
            if user_input == "RESTART":
                reset_game_state()
                continue
            if user_input == "ABOUT":
                print('name="Brain", version="1.0", author="JC", country="FR"')
                continue
            if user_input.startswith("TURN"):
                parts = user_input.split(" ", 1)
                if len(parts) < 2:
                    print("Please enter valid coordinates.")
                    continue
                try:
                    x_str, y_str = parts[1].split(",")
                    x, y = int(x_str), int(y_str)
                except (ValueError, IndexError):
                    print("Please enter valid coordinates.")
                    continue
                if not place_token(x, y, player=1):
                    print("ERROR Position already occupied! Try again.")
                    continue
                result = check_winner()
                if result:
                    print(f"Congratulations! Winner: {result}")
                    GAME_OVER = True
                    break
                execute_ai_turn()
        except ValueError:
            print("Please enter valid coordinates.")
            continue

def main():
    reset_game_state()
    main_loop()

if __name__ == "__main__":
    main()
